# ─── Microsoft Graph / OneDrive ──────────────────────────────────────────────
# Azure app registration (portal.azure.com). Use a "public client" — no secret.
ONEDRIVE_CLIENT_ID=
ONEDRIVE_TENANT_ID=common

# Written automatically by `python onedrive.py` after the first device-code login.
# Leave blank on a fresh install.
ONEDRIVE_REFRESH_TOKEN=

# ─── MCP server auth ─────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
MCP_BEARER_TOKEN=

# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Used to sign one-time upload URLs. Rotate to invalidate all in-flight URLs.
UPLOAD_SIGNING_KEY=

# ─── Public URL ──────────────────────────────────────────────────────────────
# How the world reaches this server. Used to construct signed upload URLs.
# Use a real domain, or <your-ip-with-dashes>.nip.io (e.g. 1-2-3-4.nip.io).
PUBLIC_BASE_URL=https://your-domain.example.com

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
